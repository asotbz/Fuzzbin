; openapi-typescript@7.13.0 (latest) still pins peer `typescript: ^5.x` even
; though it works fine at runtime with TypeScript 6. It's only used by the
; `generate-types` script as a CLI. Until upstream widens the peer, allow
; the install to proceed without strict peer enforcement so `npm ci` matches
; the resolution `npm install` already produced.
legacy-peer-deps=true
