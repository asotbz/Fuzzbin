@using Fuzzbin.Core.Entities
@using Fuzzbin.Core.Interfaces
@using static Fuzzbin.Core.Interfaces.IMetadataCacheService
@inject IMetadataCacheService MetadataCacheService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
            <MudText Class="mt-2">Searching for matches...</MudText>
        }
        else if (_candidates.Count > 0)
        {
            <MudText Typo="Typo.h6" Class="mb-3">
                Select Best Match for "@Video.Title" by @Video.Artist
            </MudText>
            
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                Automatic match confidence was below 90%. Please select the best match or skip to keep existing metadata.
            </MudAlert>

            <MudStack Spacing="2">
                @foreach (var (candidate, index) in _candidates.Select((c, i) => (c, i)))
                {
                    var isSelected = _selectedCandidate == candidate;
                    <MudPaper Elevation="@(isSelected ? 4 : 1)" 
                              Class="@($"pa-3 {(isSelected ? "mud-theme-primary" : "")}")"
                              Style="@(isSelected ? "border: 2px solid var(--mud-palette-primary);" : "cursor: pointer;")"
                              @onclick="@(() => SelectMatch(candidate))">
                        <MudGrid>
                            <MudItem xs="12">
                                <div class="d-flex align-center justify-space-between">
                                    <div class="flex-grow-1">
                                        <MudText Typo="Typo.subtitle1">
                                            <strong>@candidate.Title</strong>
                                        </MudText>
                                        <MudText Typo="Typo.body2">
                                            by @candidate.Artist
                                        </MudText>
                                    </div>
                                    <MudChip T="string" Size="Size.Small" Color="@GetConfidenceColor(candidate.OverallConfidence)">
                                        @((candidate.OverallConfidence * 100).ToString("F0"))% Match
                                    </MudChip>
                                </div>
                            </MudItem>
                            
                            @if (!string.IsNullOrEmpty(candidate.FeaturedArtists))
                            {
                                <MudItem xs="12">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        feat. @candidate.FeaturedArtists
                                    </MudText>
                                </MudItem>
                            }
                            
                            <MudItem xs="12">
                                <MudStack Row="true" Spacing="1">
                                    @if (candidate.Year.HasValue)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                            @candidate.Year
                                        </MudChip>
                                    }
                                    @if (!string.IsNullOrEmpty(candidate.Director))
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                            Dir: @candidate.Director
                                        </MudChip>
                                    }
                                    @if (candidate.Genres.Any())
                                    {
                                        foreach (var genre in candidate.Genres.Take(3))
                                        {
                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                                @genre
                                            </MudChip>
                                        }
                                    }
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Info">
                                        @candidate.PrimarySource
                                    </MudChip>
                                </MudStack>
                            </MudItem>
                            
                        </MudGrid>
                    </MudPaper>
                }
            </MudStack>
        }
        else
        {
            <MudAlert Severity="Severity.Warning">
                No matches found for "@Video.Title" by @Video.Artist
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Skip">Skip</MudButton>
        <MudButton Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   Disabled="@(_selectedCandidate == null)"
                   OnClick="ApplySelected">
            Apply Selected
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Video Video { get; set; } = null!;
    [Parameter] public int MaxResults { get; set; } = 5;

    private List<AggregatedCandidate> _candidates = new();
    private AggregatedCandidate? _selectedCandidate;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadMatches();
    }

    private async Task LoadMatches()
    {
        _loading = true;
        try
        {
            _candidates = await MetadataCacheService.GetCandidatesAsync(
                Video.Artist ?? string.Empty,
                Video.Title ?? string.Empty,
                MaxResults);
            
            // Auto-select the first candidate if available
            if (_candidates.Count > 0)
            {
                _selectedCandidate = _candidates[0];
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load candidates: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectMatch(AggregatedCandidate candidate)
    {
        _selectedCandidate = candidate;
    }

    private async Task ApplySelected()
    {
        if (_selectedCandidate == null) return;

        try
        {
            var updatedVideo = await MetadataCacheService.ApplyMetadataAsync(Video, _selectedCandidate);
            MudDialog.Close(DialogResult.Ok(updatedVideo));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to apply metadata: {ex.Message}", Severity.Error);
        }
    }

    private void Skip()
    {
        MudDialog.Cancel();
    }

    private Color GetConfidenceColor(double confidence)
    {
        if (confidence >= 0.9) return Color.Success;
        if (confidence >= 0.7) return Color.Info;
        if (confidence >= 0.5) return Color.Warning;
        return Color.Error;
    }
}