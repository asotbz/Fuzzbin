@page "/maintenance-history"
@using Fuzzbin.Core.Entities
@using Microsoft.AspNetCore.Components
@using MudBlazor
@using System.Collections.Generic
@using System.Linq
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<MaintenanceHistory> Logger

<PageTitle>Maintenance History - Fuzzbin</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid>
        <MudItem xs="12">
            <MudText Typo="Typo.h4" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-2" />
                Maintenance Execution History
            </MudText>
        </MudItem>
        
        <!-- Filters -->
        <MudItem xs="12">
            <MudPaper Class="pa-4 mb-4" Elevation="1">
                <MudGrid AlignItems="AlignItems.Center">
                    <MudItem xs="12" md="4">
                        <MudSelect @bind-Value="_selectedTaskFilter" 
                                   Label="Filter by Task" 
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Clearable="true">
                            <MudSelectItem Value="@((string?)null)">All Tasks</MudSelectItem>
                            <MudSelectItem Value="@("LibraryScan")">Library Scan</MudSelectItem>
                            <MudSelectItem Value="@("ThumbnailCleanup")">Thumbnail Cleanup</MudSelectItem>
                            <MudSelectItem Value="@("CachePurge")">Cache Purge</MudSelectItem>
                            <MudSelectItem Value="@("CacheStats")">Cache Statistics</MudSelectItem>
                            <MudSelectItem Value="@("RecycleBinPurge")">Recycle Bin Purge</MudSelectItem>
                            <MudSelectItem Value="@("AutoBackup")">Auto Backup</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect @bind-Value="_selectedStatusFilter" 
                                   Label="Filter by Status" 
                                   Variant="Variant.Outlined"
                                   Dense="true"
                                   Clearable="true">
                            <MudSelectItem Value="@((bool?)null)">All Status</MudSelectItem>
                            <MudSelectItem Value="@(true)">Success</MudSelectItem>
                            <MudSelectItem Value="@(false)">Failed</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="2">
                        <MudSelect T="int" 
                                   Value="_pageSize" 
                                   ValueChanged="OnPageSizeChanged"
                                   Label="Page Size" 
                                   Variant="Variant.Outlined"
                                   Dense="true">
                            <MudSelectItem Value="10">10</MudSelectItem>
                            <MudSelectItem Value="25">25</MudSelectItem>
                            <MudSelectItem Value="50">50</MudSelectItem>
                            <MudSelectItem Value="100">100</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3" Class="d-flex justify-end">
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="LoadHistoryAsync">
                            Refresh
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudItem>
        
        <!-- History Table -->
        <MudItem xs="12">
            <MudPaper Class="pa-4" Elevation="1">
                @if (_isLoading)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                }
                
                <MudTable Items="@_history" 
                          Hover="true" 
                          Dense="true"
                          Loading="@_isLoading"
                          LoadingProgressColor="Color.Primary">
                    <HeaderContent>
                        <MudTh>Task Name</MudTh>
                        <MudTh>Started At</MudTh>
                        <MudTh>Duration</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Items Processed</MudTh>
                        <MudTh>Summary</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="execution">
                        <MudTd DataLabel="Task Name">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                @execution.TaskName
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Started At">
                            @execution.StartedAt.ToLocalTime().ToString("MMM d, yyyy h:mm:ss tt")
                        </MudTd>
                        <MudTd DataLabel="Duration">@FormatDurationSeconds(execution.DurationSeconds)</MudTd>
                        <MudTd DataLabel="Status">
                            @if (execution.Success)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.CheckCircle">
                                    Success
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Icon="@Icons.Material.Filled.Error">
                                    Failed
                                </MudChip>
                            }
                        </MudTd>
                        <MudTd DataLabel="Items Processed">@execution.ItemsProcessed</MudTd>
                        <MudTd DataLabel="Summary">
                            <MudText Typo="Typo.body2" Class="text-truncate" Style="max-width: 400px;" Title="@execution.Summary">
                                @execution.Summary
                            </MudText>
                            @if (!string.IsNullOrEmpty(execution.ErrorMessage))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-1">
                                    Error: @execution.ErrorMessage
                                </MudText>
                            }
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="text-center pa-4">
                            No maintenance history found. Try adjusting your filters.
                        </MudText>
                    </NoRecordsContent>
                </MudTable>
                
                <!-- Pagination -->
                @if (_totalCount > _pageSize)
                {
                    <MudDivider Class="my-4" />
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudText Typo="Typo.body2">
                            Showing @((_currentPage - 1) * _pageSize + 1) to @Math.Min(_currentPage * _pageSize, _totalCount) of @_totalCount records
                        </MudText>
                        <MudPagination Count="@_totalPages" 
                                     Selected="@_currentPage" 
                                     SelectedChanged="OnPageChanged"
                                     Color="Color.Primary" 
                                     Variant="Variant.Filled" 
                                     ShowFirstButton="true"
                                     ShowLastButton="true" />
                    </MudStack>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<MaintenanceExecutionDto> _history = new();
    private int _totalCount;
    private int _currentPage = 1;
    private int _pageSize = 25;
    private int _totalPages => (_totalCount + _pageSize - 1) / _pageSize;
    private bool _isLoading;
    
    private string? _selectedTaskFilter;
    private bool? _selectedStatusFilter;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
    }
    
    private async Task LoadHistoryAsync()
    {
        _isLoading = true;
        StateHasChanged();
        
        try
        {
            var queryParams = new Dictionary<string, string?>
            {
                ["limit"] = _pageSize.ToString()
            };
            
            if (!string.IsNullOrEmpty(_selectedTaskFilter))
            {
                queryParams["taskName"] = _selectedTaskFilter;
            }
            
            if (_selectedStatusFilter.HasValue)
            {
                queryParams["success"] = _selectedStatusFilter.Value.ToString();
            }
            
            var queryString = string.Join("&", queryParams.Select(kvp => $"{kvp.Key}={Uri.EscapeDataString(kvp.Value ?? "")}"));
            var response = await Http.GetAsync($"/api/maintenance/history?{queryString}");
            
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<MaintenanceHistoryApiResponse>(json,
                    new System.Text.Json.JsonSerializerOptions 
                    { 
                        PropertyNameCaseInsensitive = true 
                    });
                
                if (result != null)
                {
                    _history = result.Executions;
                    _totalCount = result.Count;
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Logger.LogError("Failed to load maintenance history. Status: {StatusCode}, Content: {Content}", 
                    response.StatusCode, errorContent);
                Snackbar.Add("Failed to load maintenance history", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load maintenance history");
            Snackbar.Add($"Error loading history: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
    
    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadHistoryAsync();
    }
    
    private async Task OnPageSizeChanged(int newPageSize)
    {
        _pageSize = newPageSize;
        _currentPage = 1;
        await LoadHistoryAsync();
    }
    
    private string FormatDurationSeconds(double durationSeconds)
    {
        if (durationSeconds < 1)
            return $"{(int)(durationSeconds * 1000)}ms";
        if (durationSeconds < 60)
            return $"{durationSeconds:F1}s";
        
        var minutes = (int)(durationSeconds / 60);
        var seconds = (int)(durationSeconds % 60);
        return $"{minutes}m {seconds}s";
    }
    
    // DTO classes for API
    private class MaintenanceExecutionDto
    {
        public int Id { get; set; }
        public string TaskName { get; set; } = string.Empty;
        public DateTime StartedAt { get; set; }
        public DateTime? CompletedAt { get; set; }
        public bool Success { get; set; }
        public string Summary { get; set; } = string.Empty;
        public int ItemsProcessed { get; set; }
        public string? ErrorMessage { get; set; }
        public double DurationSeconds { get; set; }
        public Dictionary<string, object>? Metrics { get; set; }
    }
    
    private class MaintenanceHistoryApiResponse
    {
        public int Count { get; set; }
        public List<MaintenanceExecutionDto> Executions { get; set; } = new();
    }
}
