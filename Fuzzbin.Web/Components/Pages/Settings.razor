    private async Task BackupDatabase()
    {
        if (_isBackupInProgress)
        {
            Snackbar.Add("A database backup is already running", Severity.Info);
            return;
        }

        _isBackupInProgress = true;

        try
        {
            // Create the backup (retained in local storage)
            var result = await BackupService.CreateBackupAsync();
            
            // Send backup file to user as downloadable file
            await using var stream = await BackupService.GetBackupFileStreamAsync(result.FilePath);
            using var streamRef = new DotNetStreamReference(stream: stream);
            await JSRuntime.InvokeVoidAsync("Fuzzbin.downloadFileFromStream", result.FileName, streamRef);
            
            Snackbar.Add($"Backup created in /backups and downloaded: {result.FileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create backup: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBackupInProgress = false;
        }
    }

    private async Task TriggerRestoreBrowse()
    {
        if (_isRestoreInProgress)
        {
            Snackbar.Add("A database restore is already running", Severity.Info);
            return;
        }

        if (_restoreInputFile is null)
        {
            const string message = "File input element is not available. Please refresh the page.";
            _restoreStatusSeverity = Severity.Error;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Error);
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            _restoreStatusMessage = null;
            _restoreStatusSeverity = Severity.Info;
            await JSRuntime.InvokeVoidAsync("console.debug", "Settings: initiating restore file picker.");
            await InvokeAsync(StateHasChanged);

            var hasElementReference = !_restoreInputFile.Element.Equals(default(ElementReference));

            if (hasElementReference)
            {
                await JSRuntime.InvokeVoidAsync("console.debug", "Settings: triggering restore input via element reference.");
                await JSRuntime.InvokeVoidAsync("Fuzzbin.triggerFileInput", _restoreInputFile.Element);
            }
            else
            {
                await JSRuntime.InvokeVoidAsync("console.debug", "Settings: element reference not yet available, falling back to triggering by id.");
                await JSRuntime.InvokeVoidAsync("Fuzzbin.triggerFileInputById", RestoreInputElementId);
            }

            await InvokeAsync(StateHasChanged);
            _restoreStatusMessage = "Waiting for backup selection…";
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            var message = $"Unable to open file picker: {ex.Message}";
            _restoreStatusSeverity = Severity.Error;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Error);
            await InvokeAsync(StateHasChanged);
        }
    }
    
    private async Task RestoreDatabase(InputFileChangeEventArgs args)
    {
        if (_isRestoreInProgress)
        {
            Snackbar.Add("A database restore is already running", Severity.Info);
            return;
        }

        var file = args.File;
        await JSRuntime.InvokeVoidAsync("console.debug", $"Settings: restore change event received. File count: {args.FileCount}.");

        if (args.FileCount == 0 || file is null)
        {
            const string message = "No backup file selected";
            _restoreStatusSeverity = Severity.Warning;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Warning);
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!file.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
        {
            const string message = "Backup files must be ZIP archives created by Fuzzbin.";
            _restoreStatusSeverity = Severity.Warning;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Warning);
            _restoreInputKey = Guid.NewGuid();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (file.Size <= 0)
        {
            const string message = "The selected backup appears to be empty.";
            _restoreStatusSeverity = Severity.Warning;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Warning);
            _restoreInputKey = Guid.NewGuid();
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (file.Size > MaxBackupUploadBytes)
        {
            var message = $"Backup exceeds the {FormatFileSize(MaxBackupUploadBytes)} upload limit.";
            _restoreStatusSeverity = Severity.Error;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Error);
            _restoreInputKey = Guid.NewGuid();
            await InvokeAsync(StateHasChanged);
            return;
        }

        _isRestoreInProgress = true;
        _restoreStatusSeverity = Severity.Info;
        _restoreStatusMessage = $"Restoring {file.Name} ({FormatFileSize(file.Size)})…";
        await JSRuntime.InvokeVoidAsync("console.debug", $"Settings: beginning restore for {file.Name} with size {file.Size} bytes.");
        await InvokeAsync(StateHasChanged);

        try
        {
            await using var stream = file.OpenReadStream(MaxBackupUploadBytes);
            await BackupService.RestoreBackupAsync(stream);
            const string successMessage = "Database restored successfully. Restart the application to reload data.";
            _restoreStatusSeverity = Severity.Success;
            _restoreStatusMessage = successMessage;
            Snackbar.Add(successMessage, Severity.Success);
            await JSRuntime.InvokeVoidAsync("console.debug", "Settings: database restore reported success.");
        }
        catch (IOException ioEx)
        {
            var message = $"File error during restore: {ioEx.Message}";
            _restoreStatusSeverity = Severity.Error;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Error);
            await JSRuntime.InvokeVoidAsync("console.error", $"Settings: restore IO exception - {ioEx.Message}");
        }
        catch (Exception ex)
        {
            var message = $"Failed to restore database: {ex.Message}";
            _restoreStatusSeverity = Severity.Error;
            _restoreStatusMessage = message;
            Snackbar.Add(message, Severity.Error);
            await JSRuntime.InvokeVoidAsync("console.error", $"Settings: restore general exception - {ex.Message}");
        }
        finally
        {
            _isRestoreInProgress = false;
            _restoreInputKey = Guid.NewGuid();
            await InvokeAsync(StateHasChanged);
            await JSRuntime.InvokeVoidAsync("console.debug", "Settings: restore pipeline finalized; input key rotated.");
        }
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double length = bytes;
        var order = 0;

        while (length >= 1024 && order < sizes.Length - 1)
        {
            order++;
            length /= 1024;
        }

        return $"{length:0.#} {sizes[order]}";
    }
    
