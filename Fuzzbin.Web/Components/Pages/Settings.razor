    private async Task TriggerMaintenance()
    {
        if (_isMaintenanceInProgress)
        {
            return;
        }
        
        var confirm = await DialogService.ShowMessageBox(
            "Run Maintenance Now",
            "This will run cache purging and cleanup tasks. This may take a few moments. Continue?",
            "Run Maintenance",
            "Cancel");
        
        if (confirm != true)
        {
            return;
        }
        
        _isMaintenanceInProgress = true;
        await InvokeAsync(StateHasChanged);
        
        try
        {
            // Call the maintenance API endpoint
            using var httpClient = new HttpClient { BaseAddress = new Uri(Navigation.BaseUri) };
            var response = await httpClient.PostAsync("/api/maintenance/run", null);
            
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Maintenance tasks completed successfully", Severity.Success);
                await UpdateCacheStatsAsync();
                await LoadMaintenanceHistoryAsync();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Logger.LogWarning("Maintenance request failed: {Status} - {Error}", response.StatusCode, error);
                Snackbar.Add($"Maintenance failed: {response.StatusCode}", Severity.Warning);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to trigger maintenance");
            Snackbar.Add($"Maintenance failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isMaintenanceInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    
