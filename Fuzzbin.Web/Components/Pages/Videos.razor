    private async Task DeleteSelected()
    {
        if (!HasSelection)
        {
            Snackbar.Add("No videos selected", Severity.Info);
            return;
        }

        var videos = await ResolveSelectedVideosAsync();
        if (videos.Count == 0)
        {
            Snackbar.Add("Unable to resolve selected videos", Severity.Error);
            return;
        }

        var result = await ShowDeleteDialogAsync(videos);
        if (result == null)
        {
            return;
        }

        var failed = new HashSet<Guid>(result.Failures.Select(f => f.VideoId));
        foreach (var video in videos)
        {
            if (!failed.Contains(video.Id))
            {
                _videoCache.Remove(video.Id);
                _selectedVideoIds.Remove(video.Id);
            }
        }

        var deletedIds = videos
            .Where(v => !failed.Contains(v.Id))
            .Select(v => v.Id)
            .ToList();

        if (deletedIds.Count > 0)
        {
            _videos.RemoveAll(v => deletedIds.Contains(v.Id));
            StateHasChanged();
        }

        await LoadVideosAsync(clearSelection: true);
    }

