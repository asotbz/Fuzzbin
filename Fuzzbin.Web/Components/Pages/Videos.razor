    private async Task RefreshSelectedMetadata()
    {
        if (!HasSelection)
        {
            Snackbar.Add("No videos selected", Severity.Info);
            return;
        }

        var confirmParameters = new DialogParameters
        {
            { "ContentText", $"Refresh metadata for {_selectedVideoIds.Count} selected video(s)?" },
            { "ButtonText", "Refresh" },
            { "Color", Color.Primary }
        };

        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>("Refresh Metadata", confirmParameters);
        var confirmation = await confirmDialog.Result;
        if (confirmation is { Canceled: true })
        {
            return;
        }

        var videos = await ResolveSelectedVideosAsync();
        if (videos.Count == 0)
        {
            Snackbar.Add("Unable to resolve selected videos", Severity.Error);
            return;
        }

        var refreshed = 0;
        var skipped = 0;
        var failures = new List<string>();
        var isSingleVideo = videos.Count == 1;

        foreach (var video in videos)
        {
            try
            {
                var result = await MetadataService.EnrichVideoMetadataWithResultAsync(video, fetchOnlineMetadata: true);
                
                // For single video with low confidence, show manual selection dialog
                if (isSingleVideo && result.RequiresManualReview)
                {
                    // Get top 5 candidates for manual selection
                    var candidates = await MetadataCacheService.GetCandidatesAsync(
                        video.Artist ?? "",
                        video.Title ?? "",
                        maxResults: 5);
                    
                    if (candidates.Count > 0)
                    {
                        var matchParameters = new DialogParameters
                        {
                            { "Video", result.Video },
                            { "MaxResults", 5 }
                        };

                        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true };
                        var matchDialog = await DialogService.ShowAsync<MetadataMatchDialog>("Manual Match Selection Required", matchParameters, options);
                        var matchResult = await matchDialog.Result;

                        if (matchResult is { Canceled: false, Data: Video updatedVideo })
                        {
                            _videoCache[updatedVideo.Id] = updatedVideo;
                            refreshed++;
                        }
                        else
                        {
                            skipped++;
                        }
                    }
                    else
                    {
                        skipped++;
                    }
                }
                // For multi-selection with low confidence, skip automatically
                else if (!isSingleVideo && result.RequiresManualReview)
                {
                    skipped++;
                    Logger.LogInformation("Skipped video {VideoId} due to low confidence match", video.Id);
                }
                else
                {
                    _videoCache[result.Video.Id] = result.Video;
                    refreshed++;
                }
            }
            catch (Exception ex)
            {
                failures.Add($"{video.Title}: {ex.Message}");
            }
        }

        if (refreshed > 0)
        {
            Snackbar.Add($"Refreshed metadata for {refreshed} video(s).", Severity.Success);
        }

        if (skipped > 0)
        {
            Snackbar.Add($"Skipped {skipped} video(s) due to low confidence matches.", Severity.Info);
        }

        if (failures.Count > 0)
        {
            Snackbar.Add($"Failed to refresh {failures.Count} video(s).", Severity.Warning);
        }

        await LoadVideosAsync(clearSelection: false);
    }

    private async Task RefreshLibraryMetadata()
    {
        var confirmParameters = new DialogParameters
        {
            { "ContentText", "Refresh metadata for all videos in the library? This may take a long time. Videos requiring manual review will be skipped." },
            { "ButtonText", "Refresh Library" },
            { "Color", Color.Primary }
        };

        var confirmDialog = await DialogService.ShowAsync<ConfirmDialog>("Refresh Library Metadata", confirmParameters);
        var confirmation = await confirmDialog.Result;
        if (confirmation is { Canceled: true })
        {
            return;
        }

        try
        {
            Snackbar.Add("Queuing library metadata refresh...", Severity.Info);

            using var request = new HttpRequestMessage(HttpMethod.Post, "/api/jobs/RefreshMetadata");
            var response = await Http.SendAsync(request);

            if (response.StatusCode == System.Net.HttpStatusCode.Accepted)
            {
                Snackbar.Add("Library metadata refresh job queued. You'll be notified when it completes.", Severity.Success);
                
                // Show job progress dialog
                var progressParameters = new DialogParameters
                {
                    { "Title", "Library Metadata Refresh" },
                    { "JobType", "RefreshMetadata" }
                };
                var progressOptions = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium };
                await DialogService.ShowAsync<JobProgressDialog>("Metadata Refresh Progress", progressParameters, progressOptions);
            }
            else if (response.IsSuccessStatusCode)
            {
                // 200 OK indicates an existing singleton job already active
                Snackbar.Add("Library metadata refresh already running.", Severity.Info);
            }
            else
            {
                Snackbar.Add($"Failed to queue metadata refresh (HTTP {(int)response.StatusCode}).", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error queuing metadata refresh: {ex.Message}", Severity.Error);
        }
    }

